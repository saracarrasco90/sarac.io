                    <div class="absolute -bottom-4 bg-slate-900 border border-slate-700 px-4 py-2 rounded-2xl text-[10px] font-bold tracking-widest text-cyan-400">
                        SISTEMA COGNITIVO ACTIVO
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Investigación Section (Con Resúmenes AI) -->
    <section id="investigacion" class="py-24 px-6 relative bg-slate-950/30">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl font-bold text-white mb-12">Publicaciones Científicas</h2>
            
            <div class="grid md:grid-cols-2 gap-8">
                <!-- Paper 1 -->
                <div class="glass p-8 rounded-3xl border-white/5 hover:border-cyan-500/30 transition-all group">
                    <div class="flex justify-between mb-4">
                        <span class="text-[10px] font-black text-cyan-500 uppercase tracking-tighter">Social Robotics 2023</span>
                        <i class="fa-solid fa-microchip text-slate-800 group-hover:text-cyan-500/50"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-4">Introducing Psychology Strategies to Increase Engagement on Social Robots</h3>
                    <p class="text-slate-400 text-sm mb-6 line-clamp-3" id="abstract-1">
                        Estudio detallado sobre la implementación de heurísticas cognitivas y refuerzos psicológicos en el Robot Social Mini para prolongar el interés del usuario y combatir el "novelty effect".
                    </p>
                    <button onclick="summarizePaper(1)" class="flex items-center gap-2 text-[10px] font-bold text-purple-400 hover:text-purple-300 transition-colors">
                        <i class="fa-solid fa-sparkles"></i> ✨ SIMPLIFICAR CON IA
                    </button>
                </div>

                <!-- Paper 2 -->
                <div class="glass p-8 rounded-3xl border-white/5 hover:border-purple-500/30 transition-all group">
                    <div class="flex justify-between mb-4">
                        <span class="text-[10px] font-black text-purple-500 uppercase tracking-tighter">Elderly Care Pilot</span>
                        <i class="fa-solid fa-heart-pulse text-slate-800 group-hover:text-purple-500/50"></i>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-4">Social Robots Supporting Artistic Activities with Older Adults</h3>
                    <p class="text-slate-400 text-sm mb-6 line-clamp-3" id="abstract-2">
                        Evaluación experimental de una plataforma robótica que dirige talleres de pintura para personas mayores, analizando métricas de bienestar emocional y conexión social.
                    </p>
                    <button onclick="summarizePaper(2)" class="flex items-center gap-2 text-[10px] font-bold text-purple-400 hover:text-purple-300 transition-colors">
                        <i class="fa-solid fa-sparkles"></i> ✨ SIMPLIFICAR CON IA
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- ✨ Laboratorio Interactivo (Gemini API Integration) -->
    <section id="laboratorio" class="py-24 px-6">
        <div class="max-w-4xl mx-auto">
            <div class="glass p-1 rounded-3xl bg-gradient-to-br from-cyan-500/20 to-purple-500/20">
                <div class="bg-slate-950 rounded-[22px] p-8 md:p-12">
                    <div class="text-center mb-10">
                        <div class="inline-block p-3 rounded-2xl bg-cyan-500/10 mb-4">
                            <i class="fa-solid fa-flask-vial text-2xl text-cyan-400"></i>
                        </div>
                        <h2 class="text-3xl font-bold text-white">Laboratorio de Psicología Robótica ✨</h2>
                        <p class="text-slate-400 mt-2">Valida tus diálogos HRI con mi motor de análisis predoctoral.</p>
                    </div>

                    <div class="space-y-6">
                        <div>
                            <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block mb-3">Script de Interacción</label>
                            <textarea id="hri-input" rows="4" 
                                class="w-full bg-slate-900 border border-slate-800 rounded-2xl p-5 text-slate-200 focus:ring-2 focus:ring-cyan-500/50 outline-none transition-all"
                                placeholder="Escribe lo que el robot le diría al usuario..."></textarea>
                        </div>

                        <button onclick="analyzeInteraction()" id="analyze-btn" 
                            class="w-full py-5 bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 text-white font-bold rounded-2xl transition-all flex items-center justify-center gap-3 group">
                            <span>✨ ANALIZAR BONDING</span>
                            <i class="fa-solid fa-bolt-lightning group-hover:scale-125 transition-transform"></i>
                        </button>

                        <div id="ai-result" class="hidden animate-in fade-in slide-in-from-top-4 duration-500">
                            <div class="grid grid-cols-2 gap-4 mb-4">
                                <div class="glass p-4 rounded-2xl border-cyan-500/20">
                                    <div class="text-[10px] font-bold text-slate-500 uppercase">Engagement</div>
                                    <div id="res-score" class="text-2xl font-black text-cyan-400">--</div>
                                </div>
                                <div class="glass p-4 rounded-2xl border-purple-500/20">
                                    <div class="text-[10px] font-bold text-slate-500 uppercase">Heurística Principal</div>
                                    <div id="res-heuristic" class="text-xs font-bold text-purple-400 truncate">--</div>
                                </div>
                            </div>
                            <div class="glass p-5 rounded-2xl border-white/5 italic text-sm text-slate-300" id="res-feedback">
                                --
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Trayectoria Simple -->
    <section id="trayectoria" class="py-24 px-6 border-t border-white/5">
        <div class="max-w-4xl mx-auto text-center">
            <h2 class="text-2xl font-bold mb-8">Formación & Metas</h2>
            <div class="flex flex-col md:flex-row justify-center gap-12">
                <div>
                    <div class="text-cyan-400 font-bold">PhD Candidate</div>
                    <div class="text-slate-500 text-sm">UC3M Robotics Lab</div>
                </div>
                <div>
                    <div class="text-purple-400 font-bold">MSc Robotics</div>
                    <div class="text-slate-500 text-sm">Especialista HRI</div>
                </div>
                <div>
                    <div class="text-pink-400 font-bold">Industrial Engineer</div>
                    <div class="text-slate-500 text-sm">Bases en Automatización</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 border-t border-white/5 text-center">
        <div class="text-slate-600 text-[10px] font-bold tracking-widest uppercase mb-4">Sara Carrasco • SCM Portfolio 2024</div>
        <div class="flex justify-center gap-6 text-slate-400">
            <a href="mailto:sacarras@ing.uc3m.es" class="hover:text-white transition-colors"><i class="fa-solid fa-envelope"></i></a>
            <a href="#" class="hover:text-white transition-colors"><i class="fa-brands fa-linkedin"></i></a>
        </div>
    </footer>

    <!-- AI Summarizer Modal -->
    <div id="summary-modal" class="fixed inset-0 z-[60] hidden flex items-center justify-center p-6">
        <div class="absolute inset-0 modal-overlay" onclick="closeModal()"></div>
        <div class="glass max-w-lg w-full p-8 rounded-3xl border-cyan-500/30 relative z-10">
            <h4 class="text-cyan-400 font-bold text-xs tracking-widest uppercase mb-4">✨ Resumen para humanos</h4>
            <div id="modal-content" class="text-slate-200 text-sm leading-relaxed mb-6">
                Procesando investigación...
            </div>
            <button onclick="closeModal()" class="w-full py-3 rounded-xl bg-slate-800 text-white font-bold text-xs">CERRAR</button>
        </div>
    </div>

    <script>
        const apiKey = ""; // Injected at runtime

        // 1. ✨ Feature: Dynamic AI Greeting
        async function loadDynamicGreeting() {
            const greetingEl = document.getElementById('dynamic-greeting');
            const prompt = "Genera una frase corta de 5-8 palabras que sea una filosofía sobre robótica social y psicología. En español. Mayúsculas. Ejemplo: CREANDO VÍNCULOS QUE TRASCIENDAN EL SILICIO.";
            
            try {
                const response = await callGemini(prompt);
                greetingEl.innerText = response || "EL FUTURO ES HUMANO-ROBÓTICO";
            } catch (e) {
                greetingEl.innerText = "EXPLORANDO LA CONEXIÓN HUMANO-ROBOT";
            }
        }

        // 2. ✨ Feature: Research Summarizer
        async function summarizePaper(id) {
            const modal = document.getElementById('summary-modal');
            const content = document.getElementById('modal-content');
            const abstract = document.getElementById(`abstract-${id}`).innerText;
            
            modal.classList.remove('hidden');
            content.innerHTML = '<i class="fa-solid fa-circle-notch animate-spin mr-2"></i> Traduciendo ciencia a lenguaje cotidiano...';

            const prompt = `Como experta en divulgación científica, resume este abstract académico de robótica en 2 frases cortas para alguien que no sabe nada de ingeniería. Usa un tono inspirador. Texto: ${abstract}`;

            try {
                const response = await callGemini(prompt);
                content.innerText = response;
            } catch (e) {
                content.innerText = "Error al conectar con el cerebro AI.";
            }
        }

        // 3. ✨ Feature: HRI Lab Interaction Analysis
        async function analyzeInteraction() {
            const input = document.getElementById('hri-input').value;
            const btn = document.getElementById('analyze-btn');
            const resultBox = document.getElementById('ai-result');
            
            if (!input.trim()) return;

            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-dna animate-pulse"></i> ANALIZANDO PSIQUE...';

            const systemInstruction = "Eres una IA experta en HRI (Human-Robot Interaction). Analiza el diálogo de un robot y devuelve un JSON con: bondingScore (1-100), heuristic (Nombre de técnica psicológica), feedback (Consejo predoctoral experto de 1 frase).";
            
            try {
                const response = await callGeminiJSON(`Analiza este script: "${input}"`, systemInstruction);
                
                document.getElementById('res-score').innerText = response.bondingScore + '%';
                document.getElementById('res-heuristic').innerText = response.heuristic.toUpperCase();
                document.getElementById('res-feedback').innerText = response.feedback;
                
                resultBox.classList.remove('hidden');
            } catch (e) {
                console.error(e);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<span>✨ ANALIZAR BONDING</span> <i class="fa-solid fa-bolt-lightning"></i>';
            }
        }

        // --- Gemini API Helpers ---
        async function callGemini(prompt, system = "") {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: prompt }] }]
            };
            if(system) payload.systemInstruction = { parts: [{ text: system }] };

            for (let i = 0; i < 5; i++) {
                try {
                    const resp = await fetch(url, {
                        method: 'POST',
                        body: JSON.stringify(payload)
                    });
                    const data = await resp.json();
                    return data.candidates[0].content.parts[0].text.trim();
                } catch (e) {
                    await new Promise(r => setTimeout(r, Math.pow(2, i) * 1000));
                }
            }
            throw new Error("API Failure");
        }

        async function callGeminiJSON(prompt, system = "") {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: prompt }] }],
                systemInstruction: { parts: [{ text: system }] },
                generationConfig: { responseMimeType: "application/json" }
            };

            const resp = await fetch(url, { method: 'POST', body: JSON.stringify(payload) });
            const data = await resp.json();
            return JSON.parse(data.candidates[0].content.parts[0].text);
        }

        function closeModal() {
            document.getElementById('summary-modal').classList.add('hidden');
        }

        window.onload = loadDynamicGreeting;
    </script>
</body>
</html>
