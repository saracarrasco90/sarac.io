            <div id="ai-status" class="hidden md:flex items-center gap-2 text-[10px] font-bold text-cyan-500/80">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 animate-pulse"></span>
                GEMINI ACTIVE
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="sobre-mi" class="pt-32 pb-20 md:pt-48 md:pb-32 px-6 relative">
        <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
            <div class="space-y-8">
                <div id="dynamic-greeting" class="min-h-[20px] text-cyan-400 text-xs font-bold tracking-[0.2em] uppercase">
                    <!-- Loaded by AI -->
                    CARGANDO FILOSOFÍA HRI...
                </div>
                <h1 class="text-6xl md:text-8xl font-bold text-white leading-none tracking-tighter">
                    Sara <br> <span class="gradient-text">Carrasco.</span>
                </h1>
                <p class="text-lg text-slate-400 max-w-md leading-relaxed">
                    Investigadora predoctoral especializada en la <span class="text-white font-semibold">simbiosis humana</span>. Diseño la psicología detrás de los robots que nos cuidarán mañana.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="#laboratorio" class="px-8 py-4 rounded-full bg-cyan-500 text-slate-950 font-bold hover:bg-cyan-400 transition-all transform hover:-translate-y-1 shadow-lg shadow-cyan-500/20">
